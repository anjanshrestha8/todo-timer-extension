{
  "name": "timer-todo-extension",
  "displayName": "Timer & Todo Extension",
  "description": "A simple timer and todo list for VS Code",
  "publisher": "anjanshrestha8",
  "version": "1.1.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anjanshrestha8/todo-timer-extension"
  },
  "categories": [
    "Other"
  ],
  "icon": "logo.ico",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timer-todo.openTimer",
        "title": "Open Timer",
        "category": "Timer & Todo"
      },
      {
        "command": "timer-todo.openTodo",
        "title": "Open Todo List",
        "category": "Timer & Todo"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "timer-todo-sidebar",
          "title": "Timer & Todo",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "timer-todo-sidebar": [
        {
          "type": "webview",
          "id": "timer-todo.timer",
          "name": "Timer"
        },
        {
          "type": "webview",
          "id": "timer-todo.todo",
          "name": "Todo List"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
